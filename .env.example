# Variables d'environnement pour Lotus Business (exemples)

# Base
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/lotusdb
DIRECT_URL=postgresql://user:password@localhost:5432/lotusdb

# JWT
JWT_SECRET=changeme_super_secret_key

# Brevo (SMTP HTTP API)
BREVO_API_KEY=your_brevo_api_key_here
SENDER_EMAIL=no-reply@lotusbusiness.example

# App
BASE_URL=https://app.lotusbusiness.example

# Expo Push Notifications (aucune clé requise ici — tokens stockés côté utilisateur)
